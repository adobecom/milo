:root {
  /* Tab Colors */

  /*
    confirm removal:
    --tabs-active-color: #1473e6 (check- no s2a blue matches; nearest --s2a-color-blue-1000 #274dea or --s2a-color-blue-1200 #1532ad)
    --tabs-border-color: #909090 (check- nearest s2a is --s2a-color-gray-500 #8f8f8f, off by 1)
    --tabs-border-hover-color: #acacac (check- no s2a gray matches; between gray-400 #c6c6c6 and gray-500 #8f8f8f)
  */
  --tabs-text-color: #686868; /* check- nearest s2a is --s2a-color-gray-600 (#717171) */
  --tabs-active-text-color: #2c2c2c; /* check- nearest s2a is --s2a-color-gray-800 (#292929) */
  /* confirm removal: --tabs-bg-color: #f1f1f1 (check- between --s2a-color-gray-75 #f3f3f3 and --s2a-color-gray-100 #e9e9e9) */
  --tabs-active-bg-color: var(--s2a-color-gray-25);
  --tabs-list-bg-gradient: linear-gradient(
    to bottom,
    rgba(136, 136, 136, 0) 0%,
    rgba(136, 136, 136, 0) 60%,
    rgba(136, 136, 136, 0.03) 80%,
    rgba(136, 136, 136, 0.08) 100%
  ); /* check- no s2a gradient token; --s2a-color-transparent-black-* available if reformatting */

  --tabs-mobile-stacked-bg-color: #242424; /* check- nearest s2a is --s2a-color-gray-800 (#292929) */
  --tabs-mobile-stacked-text-color: var(--s2a-color-gray-25);
  --tabs-pill-bg-color: var(--s2a-color-gray-800);
  --tabs-pill-bg-color-hover: var(--s2a-color-gray-200);
  --tabs-pill-bg-focus: var(--s2a-color-gray-700);
  --tabs-pill-bg-color-active: var(--s2a-color-gray-700);
  --tabs-pill-text-focus-color: var(--s2a-color-gray-25);
  --tabs-pill-text-color: var(--s2a-color-gray-700);
  --tabs-pill-text-selected-color: var(--s2a-color-gray-25);
  --tabs-paddle-bs-color: #0000001a; /* check- #0000001a ≈ 10%; nearest s2a: --s2a-color-transparent-black-08 (8%) or --s2a-color-transparent-black-12 (12%) */
  --m-rounded-corners-tabs: var(--s2a-border-radius-sm);
}

:root .dark {
  /* confirm removal: --tabs-border-color: #909090 (check- nearest s2a is --s2a-color-gray-500 #8f8f8f, off by 1) */
  --tabs-text-color: #b6b6b6; /* check- between --s2a-color-gray-400 (#c6c6c6) and --s2a-color-gray-500 (#8f8f8f) */
  --tabs-active-text-color: var(--s2a-color-gray-25);

  /* confirm removal: --tabs-bg-color: #1a1a1a (check- between --s2a-color-gray-800 #292929 and --s2a-color-gray-900 #131313) */
  --tabs-active-bg-color: #1e1e1e; /* check- between --s2a-color-gray-800 (#292929) and --s2a-color-gray-900 (#131313) */
  --tabs-list-bg-gradient: linear-gradient(
    rgba(0, 0, 0, 0%) 0%,
    rgba(0, 0, 0, 0%) 60%,
    rgba(0, 0, 0, 20%) 80%,
    rgba(0, 0, 0, 40%) 100%
  ); /* check- no s2a gradient token; --s2a-color-transparent-black-* available if reformatting */

  --tabs-pill-bg-color: var(--s2a-color-gray-25);
  --tabs-pill-bg-focus: #6d6d6d; /* check- nearest s2a is --s2a-color-gray-600 (#717171) */
  --tabs-pill-bg-color-hover: #6d6d6d; /* check- nearest s2a is --s2a-color-gray-600 (#717171) */
  --tabs-pill-bg-color-active: #393939; /* check- between --s2a-color-gray-700 (#505050) and --s2a-color-gray-800 (#292929) */
  --tabs-pill-text-color: var(--s2a-color-gray-25);
  --tabs-pill-text-selected-color: var(--s2a-color-gray-1000);
  --tabs-pill-text-focus-color: var(--s2a-color-gray-25);
  --tabs-mobile-stacked-bg-color: var(--s2a-color-gray-25);
  --tabs-mobile-stacked-text-color: var(--s2a-color-gray-900);
  --tabs-paddle-bs-color: #ffffff1a; /* check- #ffffff1a ≈ 10%; nearest s2a: --s2a-color-transparent-white-08 (8%) or --s2a-color-transparent-white-12 (12%) */
}

.tabs {
  position: relative;
  margin: 0;
  color: var(--tabs-active-text-color);
  background-color: var(--tabs-active-bg-color);
  z-index: 1;
}

.tabs.xxl-spacing {
  padding: var(--spacing-xxl) 0; /* check- --spacing-xxl is not an s2a token */
}

.tabs.xxl-spacing .paddle {
  top: var(--spacing-xxl); /* check- --spacing-xxl is not an s2a token */
}

.tabs.xl-spacing {
  padding: var(--spacing-xl) 0; /* check- --spacing-xl is not an s2a token; s2a has --s2a-spacing-xl (32px) */
}

.tabs.xl-spacing .paddle {
  top: var(--spacing-xl); /* check- --spacing-xl is not an s2a token */
}

.tabs.l-spacing {
  padding: var(--spacing-l) 0; /* check- --spacing-l is not an s2a token */
}

.tabs.l-spacing .paddle {
  top: var(--spacing-l); /* check- --spacing-l is not an s2a token */
}

.tabs.s-spacing {
  padding: var(--spacing-s) 0; /* check- --spacing-s is not an s2a token */
}

.tabs.s-spacing .paddle {
  top: var(--spacing-s); /* check- --spacing-s is not an s2a token */
}

.tabs.xs-spacing {
  padding: var(--spacing-xs) 0; /* check- --spacing-xs is not an s2a token; s2a has --s2a-spacing-xs (8px) */
}

.tabs.xs-spacing .paddle {
  top: var(--spacing-xs); /* check- --spacing-xs is not an s2a token */
}

.tabs .tabList {
  position: relative;
  display: flex;
  z-index: 2;
  margin: 0 var(--spacing-m); /* check- --spacing-m is not an s2a token; s2a equivalent is --s2a-spacing-md (16px) */
  /* ScrollProps - If content exceeds height of container, overflow! */
  overflow: auto;
  overflow-y: hidden;
  scroll-snap-type: x mandatory;
  -ms-overflow-style: none; /* Internet Explorer 10+ */
  scrollbar-width: none; /* Firefox 64 */
}

.tabs .tabList::-webkit-scrollbar {
  display: none; /* Safari and Chrome */
}

.tabs .tab-headline {
  margin-top: var(--spacing-xxl); /* check- --spacing-xxl is not an s2a token */
  margin-bottom: var(--spacing-xl); /* check- --spacing-xl is not an s2a token */
}

.tabs.center .tab-headline {
  text-align: center;
}

.tabs .tabList .tab-list-container {
  display: flex;
  width: var(--grid-container-width);
  margin: var(--spacing-xxs) auto; /* check- --spacing-xxs is not an s2a token; s2a has --s2a-spacing-4 (4px) */
  box-sizing: content-box;
}

/* center tabs */
.tabs.center > .tabList::after,
.tabs.center > .tabList::before {
  content: "";
  margin: auto;
}

.tabs.center.segmented-control > .tabList:is(::after, ::before) {
  content: none;
}

.tabs.center:not(.same-width) .tabList .tab-list-container {
  width: auto;
}

/* mweb design */

/*
.tabs.no-border-bottom .tab-content {
  border-bottom: none;
}
*/

/* contained tabs content */
[role='tabpanel'] > .section > .content,
.tabs.contained .tab-content .tab-content-container {
  width: var(--grid-container-width);
  margin: 0 auto;
}

.tab-content [role='tabpanel'] .section {
  position: relative;
}

.tab-content [role='tabpanel'] .section picture.section-background {
  z-index: 0;
}

.tab-content [role='tabpanel'] .section > .content {
  z-index: 1;
  position: relative;
}

.tab-content [role='tabpanel'] .section[class*='-up'] > .content {
  width: 100%;
}

.tabs .tabList button {
  color: var(--tabs-pill-text-color);
  cursor: pointer;
  float: left;
  font-family: var(--body-font-family);
  font-weight: 400;
  margin: 0;
  margin-inline-start: var(--s2a-spacing-16);
  border-radius: 75px; /* check- 75px pill shape; --s2a-border-radius-round is 999px (same intent, different value) */
  border: none;
  padding: 0.2em 1em; /* check- em-based padding; no s2a token equivalent */
  text-decoration: none;
  transition: color 0.1s ease-in-out;
  white-space: nowrap;
  width: auto;
  z-index: 1;
}

.tabs.same-width .tabList button {
  flex: 1;
}

.tabs .paddle {
  position: absolute;
  cursor: pointer;
  width: var(--s2a-spacing-32);
  height: var(--s2a-spacing-48);
  top: 0;
  background: unset;
  border: none;
  padding: 14px 0 12px; /* check- 14px has no s2a token; nearest are --s2a-spacing-12 (12px) and --s2a-spacing-16 (16px) */
  display: flex;
  align-items: center;
  z-index: 3;
}

/*
.tabs.quiet .paddle {
  margin-top: 1px;
}
*/

.tabs .tabList button:first-of-type {
  margin-inline-start: 0;
}

.tabs .tabList button:hover {
  color: var(--tabs-pill-text-color);
  background: var(--tabs-pill-bg-color-hover);
}

.tabs .tabList button:active {
  color: var(--tabs-pill-text-focus-color);
  background: var(--tabs-pill-bg-color-active);
}

.tabs .tabList button:focus {
  color: var(--tabs-pill-text-focus-color);
  background: var(--tabs-pill-bg-focus);
}

.tabs .tabList button:focus-visible {
  outline: var(--s2a-border-width-md) solid #4145ca; /* check- #4145ca has no s2a match; --s2a-color-focus-ring-default is #3b63fb */
}

.tabs .tabList button[aria-selected="true"],
.tabs .tabList button[aria-checked="true"] {
  color: var(--tabs-pill-text-selected-color);
  background: var(--tabs-pill-bg-color);
  text-shadow: 0.4px 0 0 var(--tabs-pill-text-color);
}

.tabs .tabList button.l-button {
  font-size: var(--s2a-font-size-md);
  line-height: 20.8px; /* check- no s2a line-height token for 20.8px; nearest are --s2a-font-line-height-18 (18px) and --s2a-font-line-height-20 (20px) */
  height: var(--s2a-spacing-40);
}

.tabs .tabList button.m-button {
  font-size: var(--s2a-font-size-sm);
  line-height: 18.2px; /* check- no s2a line-height token for 18.2px; nearest is --s2a-font-line-height-18 (18px) */
  height: var(--s2a-spacing-32);
}

.tabs .tabList button.s-button {
  font-size: var(--s2a-font-size-xs);
  line-height: 15.6px; /* check- no s2a line-height token for 15.6px; nearest is --s2a-font-line-height-16 (16px) */
  height: var(--s2a-spacing-24);
}

/* Tabs: .quiet */

/*
.tabs.quiet .tabList button {
  border-width: 0 0 2px;
  border-color: transparent;
  background: transparent;
  padding-right: 0;
  padding-left: 0;
  margin-inline-start: 24px;
}

.tabs.quiet:is(.no-top-border, .no-border) .tabList,
.tabs.quiet:is(.no-top-border, .no-border) .paddle,
.tabs.quiet:is(.no-bottom-border, .no-border) .tab-content {
  border-bottom: none;
  box-shadow: none;
  background: none;
}

.tabs.quiet .tabList {
  padding-bottom: 1px;
}
*/

/*
.tabs.quiet .tabList button:first-of-type {
  margin-inline-start: 0;
}

.tabs.quiet .tabList button:hover {
  border-bottom-color: var(--tabs-border-hover-color);
}

.tabs.quiet .tabList button[aria-selected="true"],
.tabs.quiet .tabList button[aria-checked="true"] {
  border-bottom-color: var(--tabs-active-color);
}
*/

.tabs .paddle:disabled {
  cursor: default;
  box-shadow: none;
  background: var(--tabs-list-bg-gradient);
  background-size: 100% 16px;
  background-position: bottom;
  background-repeat: no-repeat;
}

.tabs .paddle-left {
  box-shadow: 4px 0 4px -2px var(--tabs-paddle-bs-color);
  left: 0;
}

.tabs .paddle-right {
  box-shadow: -4px 0 4px -2px var(--tabs-paddle-bs-color);
  right: 0;
}

.tabs .paddle svg {
  opacity: 1;
  width: var(--s2a-spacing-8);
  height: 14px; /* check- no s2a spacing token for 14px; nearest are --s2a-spacing-12 (12px) and --s2a-spacing-16 (16px) */
  margin: 0 auto;
  transition: opacity 150ms ease;
  color: var(--tabs-text-color);
}

.tabs .paddle-left svg {
  transform: rotate(180deg);
}

.tabs .paddle:hover svg {
  color: var(--tabs-active-text-color);
}

.tabs .paddle:disabled svg {
  opacity: 0;
}

/* Segmented Control Variant */
.tabs.segmented-control .tabs-wrapper {
  display: flex;
  width: 100%;
}

.tabs.segmented-control.center .tabs-wrapper {
  justify-content: center;
}

.tabs.segmented-control .tabList {
  box-shadow: none;
  padding: 1px; /* check- no s2a spacing token for 1px; minimum s2a spacing is --s2a-spacing-2 (2px) */
  background: var(--s2a-color-gray-100);
  border-radius: var(--m-rounded-corners-tabs);
  border: var(--s2a-border-width-sm) solid var(--s2a-color-gray-100);
  min-height: var(--s2a-spacing-40);
}

.tabs.segmented-control .tabList .tab-list-container {
  min-width: 300px; /* check- no s2a token for 300px */
  width: auto;
}

.tabs.segmented-control .tabList button {
  padding: 10px; /* check- no s2a spacing token for 10px; between --s2a-spacing-8 (8px) and --s2a-spacing-12 (12px) */
  border-radius: var(--m-rounded-corners-tabs);
  border: none;
  font-weight: var(--s2a-font-weight-adobe-clean-bold);
  color: var(--tabs-pill-bg-color);
  font-size: var(--type-body-xs-size); /* check- --type-body-xs-size is not an s2a token; s2a equivalent is --s2a-typography-font-size-body-xs */
  flex: 1 0 auto;
}

.tabs.segmented-control .tabList button[aria-selected="true"],
.tabs.segmented-control .tabList button[aria-checked="true"] {
  background: var(--tabs-pill-bg-color);
  /* color: var(--color-white); */
  color: var(--s2a-color-gray-25);
}

/* Section Metadata */
.tabs-background-transparent .tabs,
.tabs-background-transparent .tabs .tabList,
.tabs-background-transparent .tabs .tabList button[aria-selected="true"],
.tabs-background-transparent .tabs .tabList button[aria-checked="true"],
.tabs-background-transparent .tabs .tabList .paddle {
  background: transparent;
}

.tabs-background-transparent .tabs .tabList button[aria-selected="true"],
.tabs-background-transparent .tabs .tabList button[aria-checked="true"] {
  border-bottom-color: var(--tabs-active-bg-color);
}

@media screen and (min-width: 600px) {
}

@media screen and (min-width: 1200px) {
  [role='tabpanel'] > .section[class*='-up'] > .content,
  [role='tabpanel'] > .section[class*='grid-width-'] > .content {
    width: auto;
  }

  /*
  .tabs.quiet .tabList button {
    padding-top: 18px;
    padding-bottom: 18px;
  }
  */

  .tabs .paddle {
    height: 62px; /* check- no s2a spacing token for 62px; between --s2a-spacing-48 (48px) and --s2a-spacing-64 (64px) */
  }

  .tabs .paddle svg {
    top: var(--s2a-spacing-24);
  }
}

@media screen and (max-width: 599px) {
  .tabs.stacked-mobile .tabList {
    margin: 0;
  }

  .tabs.stacked-mobile .paddle {
    display: none;
  }

  .tabs.stacked-mobile .tabList .tab-list-container {
    flex-direction: column;
    margin: 30px auto; /* check- no s2a spacing token for 30px; between --s2a-spacing-24 (24px) and --s2a-spacing-32 (32px) */
  }

  .tabs.stacked-mobile .tabList button {
    font-size: var(--s2a-font-size-xl);
    white-space: unset;
    word-wrap: break-word;
    line-height: 25px; /* check- no s2a line-height token for 25px; between --s2a-font-line-height-24 (24px) and --s2a-font-line-height-32 (32px) */
    padding: var(--s2a-spacing-8);
    border-radius: 0;
    border: 0;
    margin-bottom: var(--s2a-spacing-8);
  }

  .tabs.stacked-mobile .tabList button:last-of-type {
    margin-bottom: 0;
  }

  .tabs.stacked-mobile .tabList button[aria-selected="true"],
  .tabs.stacked-mobile .tabList button[aria-checked="true"] {
    background-color: var(--tabs-mobile-stacked-bg-color);
    color: var(--tabs-mobile-stacked-text-color);
  }

  .tabs.stacked-mobile.center .tabList .tab-list-container {
    width: 100%;
    margin: 0 30px 30px; /* check- no s2a spacing token for 30px; between --s2a-spacing-24 (24px) and --s2a-spacing-32 (32px) */
  }

  /*
  .tabs.stacked-mobile.quiet .tabList button {
    margin-inline-start: 0;
  }
  */

  .tabs[class*='stacked-mobile'] .paddle {
    background: unset;
    border: none;
  }
}
