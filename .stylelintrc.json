{
  "extends": [
    "stylelint-config-standard",
    "stylelint-config-prettier"
  ],
  "rules": {
    "unit-no-unknown": [
      true,
      {
        "ignoreUnits": [
          "dvh",
          "svh"
        ]
      }
    ],
    "property-no-unknown": [
      true,
      {
        "ignoreProperties": ["animation-timeline", "animation-range", "view-timeline-name", "view-timeline-axis"]
      }
    ]
  }
}
